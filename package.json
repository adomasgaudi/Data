{
  "name": "colosseum-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Strength training dashboard. Reads StrengthLevel data (ingested via the existing Apps Script pipeline) and computes leaderboards, PRs and estimated 1RMs over the full set log.",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite index.dev.html",
    "build": "tsc --noEmit && vite build && cp dist/index.dev.html dist/index.html",
    "netlify:stage": "cp dist/index.html .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:app": "vite --config vite.app.config.ts",
    "build:app": "tsc -p tsconfig.app.json --noEmit && vite build --config vite.app.config.ts",
    "preview:app": "vite preview --config vite.app.config.ts",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "lint": "biome check app",
    "lint:fix": "biome check --write app",
    "format": "biome format --write app",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "env:encrypt": "dotenvx encrypt",
    "env:decrypt": "dotenvx decrypt"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@sentry/react": "^8.55.0",
    "@supabase/supabase-js": "^2.108.1",
    "@ts-rest/core": "^3.52.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.4",
    "i18next": "^24.2.2",
    "lucide-react": "^0.474.0",
    "papaparse": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^7.1.5",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@dotenvx/dotenvx": "^1.34.0",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^26.1.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.30.4",
    "fast-check": "^3.23.2",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.4"
  }
}
