# Copy to .env and fill in. If unset, the app renders the bundled sample fixture.

# Option 1 (simplest): point the browser straight at your Apps Script web-app URL.
# Works if the Apps Script /exec endpoint allows cross-origin GET.
# VITE_DATA_URL=https://script.google.com/macros/s/XXXX/exec

# Option 2 (recommended, no CORS worries): point at the same-origin proxy and
# configure UPSTREAM_DATA_URL in your Cloudflare/Netlify dashboard instead.
# VITE_DATA_URL=/api/data
