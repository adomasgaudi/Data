# Copy to .env only if you need to override defaults.
#
# LEGACY app: by default the site reads from its own serverless function at
# /api/data, which fetches StrengthLevel server-side. You normally do NOT need to
# set anything. When opened as a bare local file (no server), it falls back to
# the bundled sample data.

# Override the data endpoint (rarely needed):
# VITE_DATA_URL=/api/data

# ── New React app (app/) ──────────────────────────────────────────────────────
# Secrets are managed with dotenvx: `pnpm env:encrypt` encrypts this file's real
# values in-repo (keys stay out of git via .env.keys). All optional — the app
# builds and runs with none of them set.

# Sentry error/perf reporting — dormant until a DSN is set (needs a Sentry account).
# VITE_SENTRY_DSN=

# LaunchDarkly client-side ID — NOT wired yet (needs an LD account). The app uses
# a local flag stub until this is provided.
# VITE_LD_CLIENT_ID=

# Drizzle / Supabase Postgres connection string (server-side only; for db:push).
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
